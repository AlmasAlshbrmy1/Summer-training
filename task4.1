module top (
    input  [3:0] A,B,
    input C,
    output Y
);

wire AeqB;
wire AltB;
wire AgtB;
wire n1;
wire n2;

comparator U1 (
    .AeqB(AeqB),
    .AltB(AltB),
    .AgtB(AgtB),
    .A(A),
    .B(B)
);

Or2 U2 (
    .A(AgtB),
    .B(AltB),
    .Y(n1)
);

And2 U3 (
    .A(C),
    .B(C),
    .Y(n2)
);

Not1 U4 (
    .A(n2),
    .Y(Y)
);

endmodule


module Or2(
input logic  A,B,
output logic Y
    );
    assign Y= A|B;
endmodule


module And2(
input logic  A,B,
output logic Y
    );
    assign Y= A&B;
endmodule

module Not1(
input logic  A,
output logic Y
    );
    assign Y= ~A;
endmodule



module comparator(AeqB, AltB, AgtB, A, B);
input  [3:0] A,B;
output  AeqB, AltB, AgtB;



assign AeqB = (A == B)? 1 : 0;
assign AltB = (A < B)? 1 : 0;
assign AgtB = (A > B)? 1 : 0;

endmodule
